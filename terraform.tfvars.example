# Copie este arquivo para terraform.tfvars e preencha com seus valores reais
# cp terraform.tfvars.example terraform.tfvars
#
# ATENÇÃO: terraform.tfvars está no .gitignore — nunca commitar com dados reais.

aws_region          = "us-east-1"
instance_name       = "ec2-devops-lab"
instance_type       = "t3.micro"
ssh_public_key_path = "~/.ssh/id_rsa.pub"
s3_bucket_name      = "homelab-assets-seu-nome-unico"  # deve ser globalmente único na AWS
db_name             = "homelabdb"
db_username         = "dbadmin"
db_password         = "SuaSenhaSegura123!"             # use uma senha forte
